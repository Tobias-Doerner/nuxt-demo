{
  "name": "nuxt-demo",
  "version": "1.0.0",
  "description": "My ace Nuxt.js project",
  "author": "Tobias Doerner",
  "private": true,
  "scripts": {
    "dev": "nuxt",
    "build": "nuxt build",
    "start": "nuxt start",
    "export": "nuxt export",
    "serve": "nuxt serve",
    "lint:js": "eslint --ext .js,.vue --ignore-path .gitignore .",
